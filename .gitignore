# Virtual environment
venv/
.venv/
env/

# App working directories (auto-managed, never commit these)
uploads/
outputs/
converted/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Demucs model cache (large, re-downloaded automatically)
~/.cache/torch/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Environment variables
.env
.env.*

# IDE / editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Audio files (don't accidentally commit large media)
*.wav
*.mp3
*.flac
*.ogg
*.m4a
*.aac
*.wma
*.mp4